# ============================================================
# Unraid Arr Stack — Environment-Konfiguration
# ============================================================
# Kopieren und ausfüllen:
#   cp .env.example .env
# .env ist gitignored — Secrets bleiben lokal auf dem Server.

# ============================================================
# GENERAL
# ============================================================
# Unraid-Default: PUID=99 (nobody), PGID=100 (users) — prüfen mit: id $USER
PUID=99
PGID=100

# Zeitzone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/Berlin

# Basis-Pfad für Container-Configs (Unraid: /mnt/user/appdata)
APPDATA=/mnt/user/appdata

# Gemeinsamer Daten-Share — Medien UND Downloads unter einem Mount,
# damit Hardlinks/atomic moves funktionieren (TRaSH-Layout)
DATA=/mnt/user/data

# LAN-IP des Unraid-Servers
UNRAID_IP=192.168.1.100

# ============================================================
# TAILSCALE
# ============================================================
# Hostname in der Tailscale-Admin-Konsole
TS_HOSTNAME=arr-stack

# Pre-Auth-Key (https://login.tailscale.com/admin/settings/keys)
# WICHTIG: den VOLLSTÄNDIGEN Key kopieren — Format: tskey-auth-…-…
# Leer lassen für interaktives Login (URL via: docker logs tailscale)
TS_AUTHKEY=

# Extra-Flags für den Tailscale-Daemon (z. B. --ssh)
TS_EXTRA_ARGS=

# ============================================================
# USENET-PROVIDER (für SABnzbd, per Bootstrap gesetzt)
# ============================================================
EWEKA_HOST=news.eweka.nl
EWEKA_PORT=563
EWEKA_SSL=1
EWEKA_USERNAME=your_eweka_username
EWEKA_PASSWORD=your_eweka_password
EWEKA_CONNECTIONS=45

# ============================================================
# INDEXER (für Prowlarr, per Bootstrap gesetzt)
# ============================================================
SCENENZBS_URL=https://scenenzbs.com/
SCENENZBS_APIKEY=your_scenenzbs_apikey

# ============================================================
# PORTS (Host-Ports; Container-Ports bleiben fix)
# ============================================================
SABNZBD_PORT=8090
PROWLARR_PORT=9696
RADARR_PORT=7878
SONARR_PORT=8989
BAZARR_PORT=6767
SEERR_PORT=5055
JELLYFIN_PORT_HTTP=8096
JELLYFIN_PORT_HTTPS=8920
HOMEPAGE_PORT=3000

ADGUARD_SETUP_PORT=3001
ADGUARD_WEBUI_PORT=8081

# Deaktivierte Dienste (Compose-Profile)
VAULTWARDEN_PORT=8082
THREADFIN_PORT=34400
LIDARR_PORT=8686
READARR_PORT=8787

# ============================================================
# ADGUARD HOME — lokaler DNS + Werbeblocker
# ============================================================
# Login für die AdGuard-Web-UI (wird vom Bootstrap gesetzt)
ADGUARD_USER=admin
ADGUARD_PASSWORD=change_me

# Lokale Domain des Routers (Fritz!Box: fritz.box) — dafür gibt es
# DNS-Rewrites wie jellyfin.fritz.box → UNRAID_IP
LOCAL_DOMAIN=fritz.box

# Router-IP: bekommt Anfragen für LOCAL_DOMAIN + Reverse-DNS weitergeleitet
ROUTER_IP=192.168.1.1

# ============================================================
# HOMEPAGE
# ============================================================
# Erlaubte Hostnamen für das Dashboard („*“ = alle; einschränken möglich,
# z. B. auf „192.168.1.100:3000,arr-stack.tailnet-name.ts.net:3000“)
HOMEPAGE_ALLOWED_HOSTS=*

# ============================================================
# VAULTWARDEN (Profil „vaultwarden“ — aktuell deaktiviert)
# ============================================================
# Admin-Panel-Token — generieren mit: openssl rand -base64 48
# Leer = Admin-Panel deaktiviert.
VW_ADMIN_TOKEN=

# Nach dem Anlegen aller Accounts auf false setzen
VW_SIGNUPS_ALLOWED=true

# Vollständige URL inkl. Protokoll (Pflichtformat!), z. B.
#   https://arr-stack.<tailnet>.ts.net   (Tailscale Serve)
# Leer = Fallback auf http://<UNRAID_IP>:<VAULTWARDEN_PORT>
VW_DOMAIN=

# ============================================================
# LIVE TV / IPTV (Profil „iptv“ — Threadfin hinter Premiumize-VPN)
# ============================================================
# NUR der Threadfin-Traffic läuft durch dieses VPN (gluetun-Split-Tunnel),
# der restliche Stack bleibt auf der normalen Leitung.
#
# 1. Auf premiumize.me/plugins die OpenVPN-Config herunterladen und als
#    ${APPDATA}/gluetun/premiumize.ovpn auf dem Server ablegen.
# 2. VPN-Zugangsdaten (Premiumize „Customer ID" + „PIN"/Passwort) hier eintragen:
PREMIUMIZE_VPN_USER=your_premiumize_vpn_user
PREMIUMIZE_VPN_PASSWORD=your_premiumize_vpn_password

# Subnetz des arr_net (docker network inspect arr_net) — damit Jellyfin den
# Threadfin-Port erreichen kann, ohne durchs VPN zu müssen. Standard passt meist.
ARR_NET_SUBNET=172.18.0.0/16

# ============================================================
# TORRENT (Profil „torrent“ — qBittorrent hinter demselben VPN)
# ============================================================
# qBittorrent-WebUI (läuft im gluetun-Netz-Stack, aller Traffic durchs VPN).
# Aus arr_net/Sonarr erreichbar als http://gluetun:8080, im Browser über
# diesen Host-Port. Erst-Setup + Sonarr-Verdrahtung: bootstrap/12-torrent.sh
QBIT_PORT=8085

# LAN-Subnetz (für den qBittorrent-WebUI-Auth-Bypass im Heimnetz).
# Anpassen, falls dein Netz nicht 192.168.178.0/24 ist.
LAN_SUBNET=192.168.178.0/24
