# ============================================================
# Unraid Arr Stack - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# GENERAL
# ============================================================
# Your user/group IDs (run: id $USER on Unraid terminal)
# Unraid default: PUID=99 (nobody), PGID=100 (users)
PUID=99
PGID=100

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/Berlin

# Base path for all app config data (on Unraid: /mnt/user/appdata)
APPDATA=/mnt/user/appdata

# ============================================================
# MEDIA & DOWNLOAD PATHS
# ============================================================
# Root data folder — all media and downloads live here
# Unraid best practice: single share so hardlinks work across containers
DATA=/mnt/user/data

# Sub-paths (relative to DATA, created by setup.sh)
# ${DATA}/media/movies       -> finished movies
# ${DATA}/media/tv           -> finished TV shows
# ${DATA}/downloads/usenet   -> usenet downloads (incomplete + complete)

# ============================================================
# TAILSCALE
# ============================================================
# Hostname shown in the Tailscale admin console
TS_HOSTNAME=arr-stack

# Auth key (create one at https://login.tailscale.com/admin/settings/keys)
# Reusable / pre-auth keys let the container authenticate without browser login.
# Leave empty to use interactive login via the URL printed to container logs.
TS_AUTHKEY=

# Extra flags passed to the tailscale daemon (space-separated)
# Examples:
#   --advertise-tags=tag:server
#   --ssh                        (enable Tailscale SSH access)
TS_EXTRA_ARGS=

# ============================================================
# SABNZBD (Usenet)
# ============================================================
SABNZBD_PORT=8090

# ============================================================
# PROWLARR (Indexer Manager)
# ============================================================
PROWLARR_PORT=9696

# ============================================================
# RADARR (Movies)
# ============================================================
RADARR_PORT=7878

# ============================================================
# SONARR (TV Shows)
# ============================================================
SONARR_PORT=8989

# ============================================================
# LIDARR (Music) — optional, start with: --profile lidarr
# ============================================================
LIDARR_PORT=8686

# ============================================================
# READARR (Books/AudioBooks) — optional, start with: --profile readarr
# ============================================================
READARR_PORT=8787

# ============================================================
# BAZARR (Subtitles)
# ============================================================
BAZARR_PORT=6767

# ============================================================
# SEERR (Media Requests)
# ============================================================
SEERR_PORT=5055

# ============================================================
# THREADFIN (IPTV Proxy / Live TV)
# ============================================================
THREADFIN_PORT=34400

# ============================================================
# VAULTWARDEN (Bitwarden-compatible password manager)
# ============================================================
VAULTWARDEN_PORT=8082

# Admin panel token — generate a secure token with:
#   openssl rand -base64 48
# Leave empty to disable the admin panel entirely.
VW_ADMIN_TOKEN=

# Set to false after all accounts are created to block new registrations
VW_SIGNUPS_ALLOWED=true

# Full URL Vaultwarden is reachable at — used in email links and TOTP URIs.
# HTTP (Tailscale only):     http://<tailscale-ip>:8082
# HTTPS (Tailscale Serve):   https://<hostname>.<tailnet>.ts.net
VW_DOMAIN=

# ============================================================
# ADGUARD HOME (DNS ad blocker)
# ============================================================
# Your Unraid server's LAN IP — port 53 is bound here to avoid
# conflicting with the host resolver.  Example: 192.168.1.100
UNRAID_IP=192.168.1.100

# One-time setup wizard port (only needed on first start).
# Default 3001 — avoids conflict with Homepage on port 3000.
ADGUARD_SETUP_PORT=3001

# Web UI port (after initial setup wizard completes).
# Default 8081 — avoids conflict with SABnzbd web UI on 8080.
ADGUARD_WEBUI_PORT=8081

# ============================================================
# JELLYFIN (Media Server)
# ============================================================
JELLYFIN_PORT_HTTP=8096
JELLYFIN_PORT_HTTPS=8920

# Hardware transcoding device (leave empty to disable)
# For Intel QuickSync:   /dev/dri
# For Nvidia:            handled via runtime in compose file
# JELLYFIN_GPU_DEVICE=/dev/dri

# ============================================================
# HOMEPAGE (Dashboard)
# ============================================================
HOMEPAGE_PORT=3000
